{
  "management": {
    "endpoints": {
      "web": {
        "basePath": "/actuator",
        "exposure": {
          "include": [ "health", "info", "metrics", "loggers", "caches", "env", "mappings", "conditions", "metadata" ],
          "exclude": []
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
