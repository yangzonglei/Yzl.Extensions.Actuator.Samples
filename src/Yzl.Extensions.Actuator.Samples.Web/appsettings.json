{
  "management": {
    "endpoints": {
      "web": {
        "basePath": "/actuator",
        "exposure": {
          "include": [ "health", "info", "metrics", "loggers", "caches", "env", "mappings", "conditions", "metadata", "beans", "httptrace", "shutdown" ],
          "exclude": []
        }
      }
    },
    "endpoint": {
      "shutdown": {
        "enabled": true
      },
      "httptrace": {
        "enabled": true,
        "capacity": 200
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
